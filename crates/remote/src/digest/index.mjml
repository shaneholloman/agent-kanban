<mjml>
  <mj-head>
    <mj-attributes>
      <mj-all font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif" />
      <mj-text font-size="14px" line-height="1.5" color="#262626" />
      <mj-section padding="0" />
    </mj-attributes>
    <mj-style>
      a { color: #D07A2F; text-decoration: none; }
      .notification-title a { font-weight: 700; font-size: 14px; line-height: 1.4; color: #D07A2F; text-decoration: none; }
      .notification-body { margin-top: 8px; color: #262626; font-size: 14px; line-height: 1.5; }
    </mj-style>
  </mj-head>

  <mj-body background-color="#F9FAFB">
    <mj-section padding="20px 0 0" />

    <mj-section padding="32px 24px 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-text font-size="22px" font-weight="700" line-height="1.3" color="#262626">
          Hey {firstName}, you have {EVENT_PROPERTY:notificationCount} new notifications
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-text css-class="notification-title">
          <a href="{EVENT_PROPERTY:notification0Url}">{EVENT_PROPERTY:notification0Title}</a>
        </mj-text>
        <mj-text css-class="notification-body" padding-top="4px">
          {EVENT_PROPERTY:notification0Body}
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-divider border-color="#E5E7EB" border-width="1px" padding="0 0 24px" />
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-text css-class="notification-title">
          <a href="{EVENT_PROPERTY:notification1Url}">{EVENT_PROPERTY:notification1Title}</a>
        </mj-text>
        <mj-text css-class="notification-body" padding-top="4px">
          {EVENT_PROPERTY:notification1Body}
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-divider border-color="#E5E7EB" border-width="1px" padding="0 0 24px" />
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-text css-class="notification-title">
          <a href="{EVENT_PROPERTY:notification2Url}">{EVENT_PROPERTY:notification2Title}</a>
        </mj-text>
        <mj-text css-class="notification-body" padding-top="4px">
          {EVENT_PROPERTY:notification2Body}
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-divider border-color="#E5E7EB" border-width="1px" padding="0 0 24px" />
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-text css-class="notification-title">
          <a href="{EVENT_PROPERTY:notification3Url}">{EVENT_PROPERTY:notification3Title}</a>
        </mj-text>
        <mj-text css-class="notification-body" padding-top="4px">
          {EVENT_PROPERTY:notification3Body}
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-divider border-color="#E5E7EB" border-width="1px" padding="0 0 24px" />
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px 24px" background-color="#FFFFFF">
      <mj-column>
        <mj-text css-class="notification-title">
          <a href="{EVENT_PROPERTY:notification4Url}">{EVENT_PROPERTY:notification4Title}</a>
        </mj-text>
        <mj-text css-class="notification-body" padding-top="4px">
          {EVENT_PROPERTY:notification4Body}
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="8px 24px 32px" background-color="#FFFFFF">
      <mj-column>
        <mj-button background-color="#D07A2F" color="#FFFFFF" font-size="14px" font-weight="600" border-radius="6px" inner-padding="12px 24px" href="{EVENT_PROPERTY:notificationsUrl}">
          View all notifications
        </mj-button>
      </mj-column>
    </mj-section>

    <mj-section padding="24px">
      <mj-column>
        <mj-text font-size="12px" color="#9CA3AF" align="center">
          You're receiving this because you have unread notifications on Vibe Kanban.
        </mj-text>
        <mj-text font-size="12px" color="#9CA3AF" align="center" padding-top="4px">
          <a href="{unsubscribe_link}" style="color: #9CA3AF; text-decoration: underline;">Unsubscribe</a>
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="0 0 20px" />
  </mj-body>
</mjml>
